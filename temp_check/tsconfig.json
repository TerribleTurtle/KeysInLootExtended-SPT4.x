{
    "compilerOptions": {
        "allowJs": false,
        "module": "NodeNext",
        "target": "ES2022",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "downlevelIteration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "paths": {
            "@spt/*": ["./types/*"],
        },
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "tmp"]
}
